# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Microsoft Dynamics 365 / Dataverse ────────────────────────────────────
# Azure AD app registration with Dynamics CRM user_impersonation scope
D365_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
D365_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
D365_CLIENT_SECRET=your-client-secret-here
D365_ENVIRONMENT_URL=https://yourorg.crm.dynamics.com

# ── Microsoft Teams (HumanInLoopAgent approval) ───────────────────────────
# Teams channel incoming webhook — Settings → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=https://yourorg.webhook.office.com/webhookb2/...
# Power Automate HTTP trigger URL — receives {"approved": true/false} from the card
TEAMS_RESPONSE_URL=https://prod-xx.westus.logic.azure.com:443/workflows/...
